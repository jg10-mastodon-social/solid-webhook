# Required
# Base URL of this server (used for issuer, webid origin, and callback URL)
BASE_URL=http://localhost:8081

# URL to load webhook RDF configuration from
WEBHOOK_CONFIG_URL=https://jg10.solidcommunity.net/settings/webhooks.ttl

# Comma-separated list of trusted OIDC issuers
WHITELISTED_ISSUERS=https://solidcommunity.net,https://jg10.solidcommunity.net

# Namespace prefix for handler types (must end with #)
HANDLER_BASE_URL="https://jg10.solidcommunity.net/settings/webhooks.ttl#"

# Optional (defaults shown as comments):
# Solid WebID of this server (used for auth and identity). Defaults to BASE_URL/webid
# WEBID=<BASE_URL>/webid

# OIDC issuer for token verification. Defaults to BASE_URL (must match WEBID origin)
# ISSUER=<BASE_URL>

# WebID of admin for /subscriptions access. Defaults to empty (all access denied)
# ADMIN_WEBID=

# URL where this server receives webhook POSTs. Defaults to BASE_URL + WEBHOOK_ENDPOINT
# SEND_TO_URL=<BASE_URL><WEBHOOK_ENDPOINT>

# POST endpoint path for incoming webhook events
# WEBHOOK_ENDPOINT=/webhook

# Port to listen on
# PORT=8081
